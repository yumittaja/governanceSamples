      "name": "subscription_parameter"
    },
    {
      "type": 1,
      "content": {
        "json": "# Azure Security  Workbook\n\n**Scope:** `{Subscription:label}`\n\nWorkbook for Azure for Cloud security posture. This build intentionally uses **ARG-safe flat queries** only: no joins, no `let`, no dynamic cascading parameters. Subscription names are provided by the native **Subscriptions** picker and workbook header; tables preserve `subscriptionId` for query reliability."
      },
      "name": "title"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "SecurityResources\n| where type == 'microsoft.security/securescores'\n| where name == 'ascScore'\n| extend secureScorePct = todouble(properties.score.percentage) * 100\n| project subscriptionId, secureScorePct",
        "size": 4,
        "title": "Security posture - Secure Score summary",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "tiles",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "subscriptionId",
              "formatter": 15,
              "formatOptions": {
                "linkTarget": null,
                "showIcon": true
              }
            },
            {
              "columnMatch": "secureScorePct",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "icons",
                "thresholdsGrid": [
                  {
                    "operator": "<",
                    "thresholdValue": "50",
                    "representation": "4",
                    "text": "{0}{1}"
                  },
                  {
                    "operator": "<",
                    "thresholdValue": "70",
                    "representation": "2",
                    "text": "{0}{1}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "success",
                    "text": "{0}{1}"
                  }
                ],
                "compositeBarSettings": {
                  "labelText": "",
                  "columnSettings": []
                }
              }
            }
          ]
        },
        "tileSettings": {
          "titleContent": {
            "columnMatch": "subscriptionId",
            "formatter": 15,
            "formatOptions": {
              "linkTarget": null,
              "showIcon": true
            }
          },
          "leftContent": {
            "columnMatch": "secureScorePct",
            "formatter": 18,
            "formatOptions": {
              "thresholdsOptions": "icons",
              "thresholdsGrid": [
                {
                  "operator": "<",
                  "thresholdValue": "50",
                  "representation": "4",
                  "text": "{0}{1}"
                },
                {
                  "operator": "<",
                  "thresholdValue": "70",
                  "representation": "2",
                  "text": "{0}{1}"
                },
                {
                  "operator": "Default",
                  "thresholdValue": null,
                  "representation": "success",
                  "text": "{0}{1}"
                }
              ]
            },
            "numberFormat": {
              "unit": 1,
              "options": {
                "style": "decimal",
                "maximumFractionDigits": 2,
                "maximumSignificantDigits": 3
              }
            }
          },
          "showBorder": false
        }
      },
      "name": "security_score_summary"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "SecurityResources\n| where type == 'microsoft.security/assessments'\n| where tostring(properties.status.code) == 'Unhealthy'\n| extend severity = coalesce(tostring(properties.metadata.severity), 'Unknown')\n| summarize unhealthyRecommendations = count() by severity\n| order by unhealthyRecommendations desc",
        "size": 1,
        "title": "Security recommendations by severity",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "piechart"
      },
      "customWidth": "50",
      "name": "security_recommendations_by_severity"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "SecurityResources\n| where type == 'microsoft.security/assessments'\n| where tostring(properties.status.code) == 'Unhealthy'\n| summarize unhealthyRecommendations = count() by subscriptionId\n| order by unhealthyRecommendations desc",
        "size": 1,
        "title": "Security debt - Unhealthy recommendations by subscription",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
