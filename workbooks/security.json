    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "\nSecurityResources\n| where type == 'microsoft.security/securescores/securescorecontrols'\n| extend controlName = tostring(properties.displayName)\n| extend unhealthyResourceCount = toint(properties.unhealthyResourceCount)\n| where unhealthyResourceCount > 0\n| summarize totalUnhealthyResources = sum(unhealthyResourceCount)\n    by controlName\n| order by totalUnhealthyResources desc\n",
        "size": 4,
        "title": "Secure Score controls - Unhealthy resources by control",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "tiles",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "subscriptionId",
              "formatter": 15,
              "formatOptions": {
                "linkTarget": null,
                "showIcon": true
              }
            }
          ]
        },
        "tileSettings": {
          "titleContent": {
            "columnMatch": "controlName",
            "formatter": 1
          },
          "leftContent": {
            "columnMatch": "totalUnhealthyResources",
            "formatter": 12,
            "formatOptions": {
              "palette": "auto"
            },
            "numberFormat": {
              "unit": 17,
              "options": {
                "style": "decimal",
                "maximumFractionDigits": 2,
                "maximumSignificantDigits": 3
              }
            }
          },
          "showBorder": false
        },
        "graphSettings": {
          "type": 0,
          "topContent": {
            "columnMatch": "controlName",
            "formatter": 1
          },
          "centerContent": {
            "columnMatch": "totalUnhealthyResources",
            "formatter": 1,
            "numberFormat": {
              "unit": 17,
              "options": {
                "maximumSignificantDigits": 3,
                "maximumFractionDigits": 2
              }
            }
          }
        }
      },
      "name": "secure_score_controls"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "SecurityResources\n| where type == 'microsoft.security/assessments'\n| where tostring(properties.status.code) == 'Unhealthy'\n| extend recommendationName = tostring(properties.displayName)\n| extend severity = coalesce(tostring(properties.metadata.severity), 'Unknown')\n| summarize affectedResources = count() by recommendationName, severity\n| top 20 by affectedResources desc\n| order by severity",
        "size": 0,
        "title": "Top unhealthy Defender recommendations",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "{Subscription}"
        ],
        "visualization": "table",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "recommendationName",
              "formatter": 1
            },
            {
              "columnMatch": "severity",
              "formatter": 18,
              "formatOptions": {
                "thresholdsOptions": "colors",
                "thresholdsGrid": [
                  {
                    "operator": "==",
                    "thresholdValue": "High",
                    "representation": "red"
                  },
                  {
                    "operator": "==",
                    "thresholdValue": "Medium",
                    "representation": "orange",
                    "text": "{0}{1}"
                  },
                  {
                    "operator": "Default",
                    "thresholdValue": null,
                    "representation": "lightBlue",
                    "text": "{0}{1}"
                  }
                ]
              }
            }
          ],
          "sortBy": [
            {
              "itemKey": "$gen_thresholds_severity_1",
              "sortOrder": 1
            }
          ]
        },
        "sortBy": [
          {
            "itemKey": "$gen_thresholds_severity_1",
            "sortOrder": 1
          }
        ]
      },
      "name": "top_unhealthy_recommendations"
    }
